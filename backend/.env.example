# Copy to `.env` and fill in real values. Do NOT commit the real .env.

APP_NAME=enterprise-rag-knowledge-assistant
VERSION=0.1.0

# PostgreSQL (see MEMORY.md Hosting: Neon / Supabase)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/rag

# Qdrant vector DB (see MEMORY.md Hosting: Qdrant Cloud / pgvector)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# Embeddings + LLM
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_PROVIDER=openai
LLM_API_KEY=

# Auth
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
